# Copy to .env and fill in. .env is gitignored.
ANTHROPIC_API_KEY=sk-ant-...

# Only needed for `build_matrix.py --retriever embeddings|hybrid`
VOYAGE_API_KEY=pa-...

# Perplexity — supporting-authority research (argument generation + stress test).
# Get a key at https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-...

# Neo4j Aura — optional, only for neo4j_load.py --analytics
NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=...
